{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ultimate Manager",
  "version": "0.4.1",
  "identifier": "com.soundtrackgeek.bevymanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ultimate Manager",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 540,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2NDAxQkQwMUJGRUNERkYKUldUL3pmNGIwQnRBNXBBOVl3RzhKb1U1YVJGajZHQXB5M2ZtV3doQnRveWdsbjR6SWMyTjByR20K",
      "endpoints": [
        "https://github.com/soundtrackgeek/bevy_manager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
